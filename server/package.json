{
  "name": "agentpm-server",
  "version": "1.0.0",
  "description": "AgentPM 通用后端框架 - 基于 NestJS 的规格驱动交付后端",
  "private": true,
  "bin": {
    "agentpm-cli": "dist/cli/main.js"
  },
  "scripts": {
    "dev": "bash scripts/dev-setup.sh serve",
    "setup": "bash scripts/dev-setup.sh",
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "prisma db push && ts-node scripts/sync-db-comments.ts",
    "prisma:studio": "prisma studio",
    "prisma:seed": "prisma db seed",
    "sync:comments": "ts-node scripts/sync-db-comments.ts",
    "cli": "ts-node -r tsconfig-paths/register src/cli/main.ts",
    "cli:prod": "node dist/cli/main.js",
    "docker:dev": "docker compose -f docker/docker-compose.dev.yaml up -d",
    "docker:prod": "docker compose -f docker/docker-compose.yaml up -d",
    "docker:stop": "docker compose -f docker/docker-compose.yaml down"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/schedule": "^5.0.0",
    "@nestjs/swagger": "^11.0.0",
    "@prisma/client": "^6.0.0",
    "bcrypt": "^6.0.0",
    "cache-manager": "^6.0.0",
    "cache-manager-ioredis-yet": "^2.1.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "commander": "14.0.1",
    "cron": "^4.4.0",
    "handlebars": "^4.7.9",
    "ioredis": "^5.4.0",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.17.21",
    "multer": "^2.0.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "playwright": "^1.61.1",
    "prisma": "^6.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/lodash": "^4.17.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.0.0",
    "@types/passport-jwt": "^4.0.0",
    "@types/uuid": "^10.0.0",
    "source-map-support": "^0.5.21",
    "ts-loader": "^9.5.0",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
