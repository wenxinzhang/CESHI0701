# 生产部署环境变量模板
# 复制为 .env 并替换所有占位值后再部署：cp .env.example .env

# 镜像地址（由 GitHub Actions 构建并推送到 GHCR；将 OWNER/REPO 改成你的仓库）
# 例：仓库为 github.com/acme/xunjian → BACKEND_IMAGE=ghcr.io/acme/xunjian-server:latest
BACKEND_IMAGE=ghcr.io/OWNER/REPO-server:latest
FRONTEND_IMAGE=ghcr.io/OWNER/REPO-admin:latest

# 数据库配置（请改为强密码）
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_DATABASE=agentpm
MYSQL_USER=agentpm
MYSQL_PASSWORD=change_me_db
MYSQL_PORT=3306

# Redis 配置（请改为强密码）
REDIS_PASSWORD=change_me_redis
REDIS_PORT=6379

# 后端配置
BACKEND_PORT=9001

# Nginx 配置
HTTP_PORT=80
HTTPS_PORT=443

# JWT（上线前必须替换为强随机值）
JWT_SECRET=change_me_to_a_strong_random_secret
