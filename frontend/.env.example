# 前端环境变量模板 —— 复制为 .env / .env.development / .env.production 后按需填写
# 注意：VITE_ 变量会被打包进前端 bundle 并公开可见，请勿在此存放服务端机密。
# 真实的 .env* 已在 .gitignore 中忽略，不会提交到仓库。

# ===== 通用（对应 .env）=====
# 版本号
VITE_VERSION = 2.6.1
# 端口号
VITE_PORT = 3006
# 应用部署基础路径（如部署在子目录 /admin，则设置为 /admin/）
VITE_BASE_URL = /
# 权限模式【 frontend 前端模式 / backend 后端模式 】
VITE_ACCESS_MODE = backend
# Mock 模式（无需后端 API）【 true 开启 / false 关闭 】
VITE_USE_MOCK = false
# 跨域请求时是否携带 Cookie
VITE_WITH_CREDENTIALS = false
# 是否打开路由信息
VITE_OPEN_ROUTE_INFO = false
# 锁屏加密密钥（请替换为自有随机值）
VITE_LOCK_ENCRYPT_KEY = your-lock-encrypt-key

# ===== 开发（对应 .env.development）=====
# API 请求基础路径（开发用 / 走代理）
VITE_API_URL = /
# 代理目标地址（开发环境 Vite 代理转发到此，解决跨域）
VITE_API_PROXY_URL = http://localhost:9001
# 是否移除 console
VITE_DROP_CONSOLE = false
# 高德地图 Key / Secret（在高德开放平台申请后填写；与 mobile 项目共用）
VITE_AMAP_KEY = your-amap-key
VITE_AMAP_SECRET = your-amap-secret

# ===== 生产（对应 .env.production）=====
# 生产环境 VITE_DROP_CONSOLE 建议为 true
